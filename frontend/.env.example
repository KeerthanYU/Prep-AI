# Frontend Vite env example. Prefix keys with VITE_ so they are available to the client.
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_API_URL=http://localhost:5000/api
# ===================================
# PrepMate AI - Frontend Configuration
# ===================================
# IMPORTANT: Never commit .env file with real credentials to version control

# API Configuration
VITE_API_URL=http://localhost:5000/api


# Application Settings
VITE_APP_NAME=PrepMate AI
VITE_APP_VERSION=1.0.0
